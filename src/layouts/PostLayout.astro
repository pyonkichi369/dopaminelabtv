---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;

const dateStr = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<BaseLayout
  title={frontmatter.title}
  description={frontmatter.excerpt}
>
  <div class="container">
    <div class="article-header">
      <div class="post-tags">
        {frontmatter.tags?.map((t: string) => (
          <span class="tag">{t}</span>
        ))}
      </div>
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <span class="date">{dateStr}</span>
        {frontmatter.readTime && <span class="read-time">{frontmatter.readTime} min read</span>}
      </div>
    </div>

    <div class="article-body">
      <slot />

      <div class="cta-block">
        <p>New research → human language. Every week.</p>
        <a class="btn" href="https://dopaminelab.substack.com" target="_blank" rel="noopener">
          Subscribe on Substack
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
