---
import BaseLayout from './BaseLayout.astro';

const { frontmatter, lang = 'en', ogImage } = Astro.props;
const sources: { name: string; url?: string }[] = frontmatter.sources ?? [];

const isJa = lang === 'ja';
const dateStr = new Date(frontmatter.date).toLocaleDateString(
  isJa ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const tags: string[] = frontmatter.tags ?? [];
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Share
const shareHashtags = isJa ? '#ドーパミン #脳科学 #集中力' : '#dopamine #neuroscience #focus';
const shareText = isJa
  ? `「${frontmatter.title}」\n${shareHashtags}\n${canonicalURL}`
  : `"${frontmatter.title}" — The science of staying human.\n${shareHashtags}\n${canonicalURL}`;
const xShareURL = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}`;
const pinterestURL = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(canonicalURL.toString())}&description=${encodeURIComponent(frontmatter.title)}`;
const lineURL = `https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(canonicalURL.toString())}`;
const linkedinURL = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL.toString())}`;

function tagHref(t: string) {
  return isJa ? `/ja/tags/${t}` : `/tags/${t.toLowerCase().replace(/\s+/g, '-')}`;
}

// Breadcrumb
const homeLabel = isJa ? 'ホーム' : 'Home';
const postsLabel = isJa ? '記事' : 'Posts';
const homeURL = isJa ? `${Astro.site}ja/` : `${Astro.site}`;
const postsURL = isJa ? `${Astro.site}ja/posts/` : `${Astro.site}posts/`;
const breadcrumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: homeURL },
    { '@type': 'ListItem', position: 2, name: postsLabel, item: postsURL },
    { '@type': 'ListItem', position: 3, name: frontmatter.title, item: canonicalURL.toString() },
  ],
};

// Related posts
const allPosts = await Astro.glob('../content/posts/**/*.md');
const currentSlug = Astro.url.pathname.split('/').filter(Boolean).pop() ?? '';
const related = allPosts
  .filter(p => {
    const parts = p.file.split('/');
    const postLang = parts[parts.length - 2];
    const postSlug = parts[parts.length - 1].replace('.md', '');
    return (
      postLang === lang &&
      postSlug !== currentSlug &&
      p.frontmatter.tags?.some((t: string) => tags.includes(t))
    );
  })
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3)
  .map(p => {
    const postSlug = p.file.split('/').pop()!.replace('.md', '');
    return {
      url: lang === 'ja' ? `/ja/posts/${postSlug}` : `/posts/${postSlug}`,
      title: p.frontmatter.title as string,
      excerpt: p.frontmatter.excerpt as string,
      tags: (p.frontmatter.tags ?? []) as string[],
      readTime: p.frontmatter.readTime as number | undefined,
    };
  });
---
<BaseLayout
  title={frontmatter.title}
  description={frontmatter.excerpt}
  ogImage={ogImage}
  lang={lang}
  article={{ publishedTime: frontmatter.date, tags, sources }}
>
  <div class="reading-progress" id="reading-progress" role="progressbar" aria-valuemin={0} aria-valuemax={100} aria-valuenow={0}></div>

  <div class="container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href={isJa ? '/ja/' : '/'}>{homeLabel}</a>
      <span aria-hidden="true">›</span>
      <a href={isJa ? '/ja/posts' : '/posts'}>{postsLabel}</a>
      <span aria-hidden="true">›</span>
      <span class="breadcrumb-current" aria-current="page">{frontmatter.title}</span>
    </nav>

    <div class="article-header">
      <div class="post-tags">
        {tags.map(t => <a href={tagHref(t)} class="tag">{t}</a>)}
      </div>
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <span class="date">{dateStr}</span>
        {frontmatter.readTime && (
          <span class="read-time">{frontmatter.readTime}{isJa ? ' 分' : ' min read'}</span>
        )}
      </div>
    </div>

    <!-- ToC — JS-populated, hidden until headings found -->
    <nav class="toc" id="toc" style="display:none" aria-label={isJa ? '目次' : 'Table of contents'}>
      <p class="toc-label">{isJa ? '目次' : 'Contents'}</p>
      <ol class="toc-list" id="toc-list"></ol>
    </nav>

    <div class="article-body" id="article-body">
      <slot />

      <div class="cta-block">
        <p>{isJa ? 'あなたの脳は今、どの状態ですか？' : 'What state is your brain in right now?'}</p>
        <a class="btn" href={isJa ? '/ja/#check' : '/#check'}>
          {isJa ? '3分でチェックする →' : 'Check in 3 minutes →'}
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="newsletter-cta">
      <span class="newsletter-cta-eyebrow">{isJa ? 'ラボレポート' : 'THE LAB REPORT'}</span>
      <h3 class="newsletter-cta-title">
        {isJa ? '毎週日曜、脳科学の新知見をお届け。' : 'New research dispatches, every Sunday.'}
      </h3>
      <p class="newsletter-cta-desc">
        {isJa
          ? '集中力・ドーパミン・AI時代の注意——無料、広告なし。'
          : 'Dopamine, focus, attention in the AI age — free, no fluff.'}
      </p>
      <a
        class="btn newsletter-cta-btn"
        href="https://dopaminelabtv.substack.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        {isJa ? 'Substackで購読する →' : 'Subscribe on Substack →'}
      </a>
    </div>

    <!-- Share -->
    <div class="article-share">
      <p class="article-share-label">{isJa ? 'この記事をシェアする' : 'Share this article'}</p>
      <div class="article-share-btns">
        <a
          class="article-share-btn article-share-btn--x"
          href={xShareURL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on X (Twitter)"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          {isJa ? 'Xでシェア' : 'Share on X'}
        </a>
        <a
          class="article-share-btn article-share-btn--linkedin"
          href={linkedinURL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Share on LinkedIn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a
          class="article-share-btn article-share-btn--pinterest"
          href={pinterestURL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Save to Pinterest"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
          </svg>
          {isJa ? '保存' : 'Pin it'}
        </a>
        {isJa && (
          <a
            class="article-share-btn article-share-btn--line"
            href={lineURL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LINEでシェア"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
            LINE
          </a>
        )}
        <button class="article-share-btn article-share-btn--copy" id="copy-link-btn" aria-label="Copy link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <span id="copy-link-text">{isJa ? 'リンクをコピー' : 'Copy link'}</span>
        </button>
      </div>
    </div>

    <!-- Related posts -->
    {related.length > 0 && (
      <section class="related-posts">
        <p class="section-label">{isJa ? '関連記事' : 'Related'}</p>
        <div class="related-grid">
          {related.map(p => (
            <a href={p.url} class="related-card">
              <div class="related-card-tags">
                {p.tags.slice(0, 2).map(t => <a href={tagHref(t)} class="tag">{t}</a>)}
              </div>
              <h3 class="related-card-title" style={isJa ? 'font-family: var(--font-jp)' : ''}>{p.title}</h3>
              {p.readTime && (
                <span class="related-card-meta">{p.readTime}{isJa ? ' 分' : ' min'}</span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <!-- Breadcrumb JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />

  <!-- Back to top button -->
  <button class="back-to-top" id="back-to-top" aria-label={isJa ? 'トップへ戻る' : 'Back to top'}>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <!-- Speakable JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org/',
    '@type': 'WebPage',
    name: frontmatter.title,
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.article-header h1', '.article-body > p:first-child'],
    },
    url: canonicalURL.toString(),
  })} />
</BaseLayout>

<script>
(function () {
  // Reading progress
  const bar = document.getElementById('reading-progress') as HTMLElement | null;
  const articleBody = document.getElementById('article-body') as HTMLElement | null;
  if (bar && articleBody) {
    function updateProgress() {
      const rect = articleBody!.getBoundingClientRect();
      const pct = Math.min(100, Math.max(0, (-rect.top / articleBody!.offsetHeight) * 100));
      bar!.style.width = pct + '%';
      bar!.setAttribute('aria-valuenow', String(Math.round(pct)));
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  // Copy link
  const copyBtn = document.getElementById('copy-link-btn');
  const copyText = document.getElementById('copy-link-text');
  if (copyBtn && copyText) {
    const original = copyText.textContent ?? '';
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyText.textContent = original.includes('コピー') ? 'コピー完了!' : 'Copied!';
        copyBtn.classList.add('article-share-btn--copied');
        setTimeout(() => {
          copyText.textContent = original;
          copyBtn.classList.remove('article-share-btn--copied');
        }, 2000);
      } catch { /* clipboard not available */ }
    });
  }

  // Table of Contents
  const tocEl = document.getElementById('toc') as HTMLElement | null;
  const tocList = document.getElementById('toc-list');
  const body = document.getElementById('article-body');
  if (tocEl && tocList && body) {
    const headings = Array.from(body.querySelectorAll('h2, h3')) as HTMLElement[];
    if (headings.length >= 2) {
      headings.forEach((h, i) => {
        if (!h.id) {
          const slug = (h.textContent ?? '')
            .toLowerCase()
            .replace(/[^\w\s぀-ヿ一-鿿-]/g, '')
            .replace(/\s+/g, '-')
            .slice(0, 40);
          h.id = 'h-' + i + '-' + slug;
        }
        const li = document.createElement('li');
        li.className = h.tagName === 'H3' ? 'toc-item toc-item--sub' : 'toc-item';
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        li.appendChild(a);
        tocList.appendChild(li);
      });
      tocEl.style.display = '';

      // Scroll spy
      const links = tocList.querySelectorAll('a');
      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              links.forEach(l => l.classList.remove('toc-link--active'));
              const active = tocList.querySelector(`a[href="#${entry.target.id}"]`);
              if (active) active.classList.add('toc-link--active');
            }
          });
        },
        { rootMargin: '-20% 0px -70% 0px' }
      );
      headings.forEach(h => observer.observe(h));

      // Heading anchor links
      headings.forEach(h => {
        const anchor = document.createElement('a');
        anchor.href = '#' + h.id;
        anchor.className = 'heading-anchor';
        anchor.setAttribute('aria-label', 'Link to this section');
        anchor.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
        h.appendChild(anchor);
      });
    }
  }

  // Back to top
  const backToTop = document.getElementById('back-to-top');
  if (backToTop) {
    window.addEventListener('scroll', () => {
      backToTop.classList.toggle('back-to-top--visible', window.scrollY > 400);
    }, { passive: true });
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
})();
</script>
