---
import '../styles/global.css';
import AudioPlayer from '../components/AudioPlayer.astro';
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: 'en' | 'ja';
  article?: {
    publishedTime: string;
    tags: string[];
    sources?: { name: string; url?: string }[];
  };
}

const {
  title,
  description = 'Neuroscience × Japanese philosophy for the AI age. Research on dopamine, attention, and staying focused in the era of AI.',
  ogImage = '/og-default.png',
  lang = 'en',
  article,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const enURL = lang === 'en'
  ? canonicalURL
  : new URL(Astro.url.pathname.replace(/^\/ja/, '') || '/', Astro.site);
const jaURL = lang === 'ja'
  ? canonicalURL
  : new URL('/ja' + Astro.url.pathname, Astro.site);
const siteName = 'Dopamine Lab TV';
const fullTitle = title === 'The Lab is Open' ? `${siteName} — The science of staying human.` : `${title} | ${siteName}`;

// JSON-LD
const isArticle = !!article;
const jsonLD = isArticle ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: new URL(ogImage, Astro.site).toString(),
  datePublished: article?.publishedTime,
  author: { '@type': 'Organization', name: siteName, url: Astro.site?.toString() },
  publisher: { '@type': 'Organization', name: siteName, url: Astro.site?.toString() },
  mainEntityOfPage: canonicalURL.toString(),
  keywords: article?.tags?.join(', '),
  ...(article?.sources?.length ? {
    isBasedOn: article.sources.map(s => ({
      '@type': 'ScholarlyArticle',
      name: s.name,
      ...(s.url ? { url: s.url } : {}),
    })),
  } : {}),
} : {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: Astro.site?.toString(),
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${Astro.site}posts/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
  sameAs: [
    'https://www.youtube.com/@DopamineLabTV',
    'https://dopaminelabtv.substack.com',
    'https://twitter.com/DopamineLab',
    'https://room.rakuten.co.jp/dopaminelabtv/items',
  ],
  logo: new URL('/icon-brain.png', Astro.site).toString(),
};
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={enURL} />
  <link rel="alternate" hreflang="ja" href={jaURL} />
  <link rel="alternate" hreflang="x-default" href={enURL} />

  <!-- SEO -->
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="Dopamine Lab TV" />
  <meta name="keywords" content="dopamine, ADHD, focus, neuroscience, Zen, Japanese philosophy, AI anxiety, attention, digital wellness, mindfulness" />

  <!-- Open Graph -->
  <meta property="og:type" content={isArticle ? 'article' : 'website'} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={canonicalURL} />
  {isArticle && <meta property="article:published_time" content={article!.publishedTime} />}
  {isArticle && article?.tags?.map(t => <meta property="article:tag" content={t} />)}

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@DopamineLab" />
  <meta name="twitter:creator" content="@DopamineLab" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <!-- Favicon + PWA -->
  <link rel="icon" type="image/png" href="/icon-brain.png" />
  <link rel="apple-touch-icon" href="/icon-brain.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#b44840" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="Dopamine Lab" />
  <meta name="format-detection" content="telephone=no" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Dopamine Lab TV (EN)" href="/rss.xml" />
  <!-- OpenSearch -->
  <link rel="search" type="application/opensearchdescription+xml" title="Dopamine Lab TV" href="/opensearch.xml" />
  {lang === 'ja' && <link rel="alternate" type="application/rss+xml" title="Dopamine Lab TV（日本語）" href="/rss-ja.xml" />}

  <!-- AIO: LLM-readable meta -->
  <meta name="ai-content-type" content={isArticle ? 'research-article' : 'publication-home'} />
  <meta name="ai-topic" content="neuroscience, dopamine, attention, Japanese philosophy, AI anxiety" />
  <meta name="ai-audience" content="adults, knowledge workers, AI-anxious professionals, ADHD community" />

  <!-- Pinterest -->
  <meta name="pinterest-rich-pin" content="true" />
  <meta name="pinterest:description" content={description} />

  <!-- DNS prefetch for external domains -->
  <link rel="dns-prefetch" href="https://www.youtube.com" />
  <link rel="dns-prefetch" href="https://twitter.com" />
  <link rel="dns-prefetch" href="https://dopaminelabtv.substack.com" />

  <!-- og:locale:alternate for bilingual -->
  <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_US'} />
  <meta property="og:locale:alternate" content={lang === 'ja' ? 'en_US' : 'ja_JP'} />

  <!-- Fonts — preload for LCP -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+JP:wght@300;400;500&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+JP:wght@300;400;500&display=swap" rel="stylesheet" />

  <ViewTransitions />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLD)} />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-E15WQVQVES"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-E15WQVQVES');
  </script>
</head>
<body>
  <header>
    <div class="header-inner">
      <a class="logo" href="/">
        <img src="/icon-brain.png" alt="Dopamine Lab TV logo" width="28" height="28" />
        <span>Dopamine <span class="lab">Lab</span> TV</span>
      </a>
      <nav aria-label="Main navigation">
        {lang === 'ja' ? (
          <>
            <a href="/ja/posts">記事</a>
            <a href="/ja/challenge" class="nav-challenge">バトル</a>
            <a href="/ja/about">About</a>
            <a href="https://www.youtube.com/@DopamineLabTV" target="_blank" rel="noopener">YouTube</a>
            <a href="https://dopaminelabtv.substack.com" target="_blank" rel="noopener">Newsletter</a>
            <a href="/" class="lang-switch">EN</a>
          </>
        ) : (
          <>
            <a href="/posts">Articles</a>
            <a href="/challenge" class="nav-challenge">Battle</a>
            <a href="/about">About</a>
            <a href="https://www.youtube.com/@DopamineLabTV" target="_blank" rel="noopener">YouTube</a>
            <a href="https://dopaminelabtv.substack.com" target="_blank" rel="noopener">Newsletter</a>
            <a href="/ja/" class="lang-switch">JP</a>
          </>
        )}
      </nav>
      <div class="header-mobile-controls">
        {lang === 'ja'
          ? <a href="/" class="lang-switch header-lang-switch">EN</a>
          : <a href="/ja/" class="lang-switch header-lang-switch">JP</a>
        }
        <button class="nav-toggle" aria-label="メニューを開く" aria-expanded="false" aria-controls="mobile-nav">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- Mobile nav overlay -->
  <div class="mobile-nav" id="mobile-nav" aria-hidden="true" role="dialog" aria-label="ナビゲーション">
    <div class="mobile-nav-inner">
      <span class="mobile-nav-kanji" aria-hidden="true">道</span>
      <nav class="mobile-nav-links" aria-label="モバイルナビゲーション">
        {lang === 'ja' ? (
          <>
            <a href="/ja/posts" class="mobile-nav-link">記事</a>
            <a href="/ja/challenge" class="mobile-nav-link">習慣バトル</a>
            <a href="/ja/about" class="mobile-nav-link">About</a>
            <a href="https://www.youtube.com/@DopamineLabTV" class="mobile-nav-link" target="_blank" rel="noopener">YouTube</a>
            <a href="https://dopaminelabtv.substack.com" class="mobile-nav-link" target="_blank" rel="noopener">Newsletter</a>
          </>
        ) : (
          <>
            <a href="/posts" class="mobile-nav-link">Articles</a>
            <a href="/challenge" class="mobile-nav-link">Habit Battle</a>
            <a href="/about" class="mobile-nav-link">About</a>
            <a href="https://www.youtube.com/@DopamineLabTV" class="mobile-nav-link" target="_blank" rel="noopener">YouTube</a>
            <a href="https://dopaminelabtv.substack.com" class="mobile-nav-link" target="_blank" rel="noopener">Newsletter</a>
          </>
        )}
      </nav>
    </div>
  </div>

  <main id="main-content">
    <slot />
  </main>

  <AudioPlayer transition:persist />

  <footer>
    <div class="footer-inner">
      <p class="footer-copy">© 2026 Dopamine Lab TV · The science of staying human.</p>
      <div class="footer-links">
        <a href="https://www.youtube.com/@DopamineLabTV" target="_blank" rel="noopener">YouTube</a>
        <a href="https://dopaminelabtv.substack.com" target="_blank" rel="noopener">Substack</a>
        <a href="/about">About</a>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
      const mobileNav = document.querySelector<HTMLElement>('.mobile-nav');
      if (!toggle || !mobileNav) return;

      function openNav() {
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'メニューを閉じる');
        mobileNav.setAttribute('aria-hidden', 'false');
        document.body.classList.add('nav-open');
        document.body.style.overflow = 'hidden';
      }

      function closeNav() {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'メニューを開く');
        mobileNav.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('nav-open');
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', () => {
        toggle.getAttribute('aria-expanded') === 'true' ? closeNav() : openNav();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeNav();
      });

      mobileNav.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeNav);
      });
    })();
  </script>
</body>
</html>
