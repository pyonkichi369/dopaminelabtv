---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('../../content/posts/en/*.md');
const posts = allPosts.sort(
  (a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
const now = Date.now();

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
function slug(p: any) { return p.file.split('/').pop().replace('.md', ''); }
function isNew(date: string) { return (new Date(date).getTime() + 14 * 86400000) > now; }
function tagHref(t: string) { return `/tags/${t.toLowerCase().replace(/\s+/g, '-')}`; }
---
<BaseLayout title="All Articles" description="All research dispatches from Dopamine Lab TV. Neuroscience × Japanese philosophy for the AI age.">
  <div class="container">
    <section class="posts-section" style="padding-top: 52px;">
      <p class="section-label">All Articles — {posts.length} dispatches</p>
      <div class="search-bar">
        <input
          type="search"
          id="post-search"
          class="search-input"
          placeholder="Search articles…"
          aria-label="Search articles"
          autocomplete="off"
        />
      </div>
      <p class="search-empty" id="search-empty" hidden>No articles found.</p>
      <div class="posts-list">
        {posts.map(post => (
          <article class="post-card">
            <div class="post-card-body">
              <div class="post-tags">
                {isNew(post.frontmatter.date) && <span class="tag-new">NEW</span>}
                {post.frontmatter.tags?.map((t: string) => <a href={tagHref(t)} class="tag">{t}</a>)}
              </div>
              <h2><a href={`/posts/${slug(post)}`}>{post.frontmatter.title}</a></h2>
              <p class="post-excerpt">{post.frontmatter.excerpt}</p>
            </div>
            <div class="post-meta">
              <span class="date">{formatDate(post.frontmatter.date)}</span>
              {post.frontmatter.readTime && <span class="read-time">{post.frontmatter.readTime} min</span>}
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>

<script is:inline>
(function () {
  var input = document.getElementById('post-search');
  var emptyMsg = document.getElementById('search-empty');
  if (!input) return;
  input.addEventListener('input', function () {
    var q = input.value.toLowerCase().trim();
    var cards = document.querySelectorAll('.posts-list .post-card');
    var visible = 0;
    cards.forEach(function (card) {
      var title = (card.querySelector('h2') || {}).textContent || '';
      var excerpt = (card.querySelector('.post-excerpt') || {}).textContent || '';
      var show = !q || title.toLowerCase().includes(q) || excerpt.toLowerCase().includes(q);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyMsg) emptyMsg.hidden = visible > 0;
  });
})();
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'All Articles — Dopamine Lab TV',
  description: 'All research dispatches. Neuroscience × Japanese philosophy for the AI age.',
  url: 'https://dopaminelabtv.com/posts/',
  hasPart: posts.map(post => ({
    '@type': 'Article',
    headline: post.frontmatter.title,
    description: post.frontmatter.excerpt,
    url: `https://dopaminelabtv.com/posts/${slug(post)}/`,
    datePublished: post.frontmatter.date,
    keywords: post.frontmatter.tags?.join(', '),
  })),
})} />
</BaseLayout>
