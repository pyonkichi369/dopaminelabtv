---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('../../content/posts/*.md');
const posts = allPosts.sort(
  (a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function slug(p: any) {
  return p.file.split('/').pop().replace('.md', '');
}
---
<BaseLayout title="All Articles" description="All research dispatches from Dopamine Lab TV.">
  <div class="container">
    <section class="posts-section" style="padding-top: 52px;">
      <p class="section-label">All Articles — {posts.length} dispatches</p>

      <div class="posts-list">
        {posts.map(post => (
          <article class="post-card">
            <div class="post-card-body">
              <div class="post-tags">
                {post.frontmatter.tags?.map((t: string) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
              <h2><a href={`/posts/${slug(post)}`}>{post.frontmatter.title}</a></h2>
              <p class="post-excerpt">{post.frontmatter.excerpt}</p>
            </div>
            <div class="post-meta">
              <span class="date">{formatDate(post.frontmatter.date)}</span>
              {post.frontmatter.readTime && (
                <span class="read-time">{post.frontmatter.readTime} min</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
