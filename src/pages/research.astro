---
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = Object.entries(
  import.meta.glob('../content/posts/en/*.md', { eager: true }) as Record<string, any>
).map(([path, mod]) => ({
  slug: path.split('/').pop()!.replace('.md', ''),
  title: mod.frontmatter?.title ?? '',
  date: mod.frontmatter?.date ?? '',
  sources: (mod.frontmatter?.sources ?? []) as { name: string; url?: string }[],
}))
.filter(p => p.sources.length > 0)
.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const totalSources = allPosts.reduce((n, p) => n + p.sources.length, 0);
---

<BaseLayout
  title="Research & Evidence | Dopamine Lab TV"
  description="Every claim on this site is sourced. A complete index of the peer-reviewed studies, journals, and research that inform our articles on dopamine, focus, and neuroscience."
  lang="en"
  ogImage="/og/research.png"
>
  <div class="research-page">
    <div class="research-hero">
      <p class="research-eyebrow">Evidence Library</p>
      <h1 class="research-title">Research & Sources</h1>
      <p class="research-subtitle">
        Every claim on this site is grounded in peer-reviewed science.
        {totalSources} sources across {allPosts.length} articles.
      </p>
      <a href="/ja/research" class="glossary-lang-switch">日本語版 →</a>
    </div>

    <div class="research-entries">
      {allPosts.map(post => (
        <div class="research-article">
          <div class="research-article-header">
            <a href={`/posts/${post.slug}`} class="research-article-title">{post.title}</a>
            <span class="research-article-count">{post.sources.length} source{post.sources.length !== 1 ? 's' : ''}</span>
          </div>
          <ul class="research-sources">
            {post.sources.map(s => (
              <li class="research-source">
                {s.url
                  ? <a href={s.url} target="_blank" rel="noopener noreferrer" class="research-source-link">{s.name}</a>
                  : <span>{s.name}</span>
                }
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="research-note">
      <p>
        Sources are listed as cited in each article. Where possible, direct links to abstracts or full texts are provided.
        All studies were published in peer-reviewed journals unless otherwise noted.
      </p>
    </div>
  </div>
</BaseLayout>
