---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="ドーパミン習慣バトル"
  description="2つの集中習慣が対決。どっちが最強？投票してコミュニティの結果を確認。毎週更新。"
  lang="ja"
>
  <div class="container">
    <section class="challenge-section">
      <div class="challenge-intro">
        <p class="section-label">週次チャレンジ</p>
        <h1 style="font-family: var(--font-jp)">習慣<span style="color:var(--accent)">バトル</span></h1>
        <p class="challenge-desc" style="font-family: var(--font-jp)">
          2つの習慣、1回の対決。どっちが集中力に効くか？<br />
          投票して、コミュニティの結果を見て、シェアする。
        </p>
      </div>

      <div id="challenge-week-label" class="challenge-week-label"></div>

      <div class="challenge-card" id="challenge-card">
        <div id="matchup-view"></div>
        <div id="result-view" hidden></div>
      </div>

      <div class="challenge-archive" id="challenge-archive"></div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
(function () {
  var MATCHUPS = [
    {
      week: 1,
      title: 'Round 1',
      a: { id: 'meditation',  name: '瞑想',       emoji: '🧘', desc: '1日10分、ただ呼吸に集中する' },
      b: { id: 'phone-detox', name: 'スマホ断ち', emoji: '📵', desc: '朝の1時間はスマホを見ない' },
      split: [58, 42],
    },
    {
      week: 2,
      title: 'Round 2',
      a: { id: 'exercise',     name: '朝の運動', emoji: '🏃', desc: '9時前に30分の有酸素運動' },
      b: { id: 'early-rising', name: '早起き',   emoji: '🌅', desc: '6時前に起きる、スヌーズなし' },
      split: [63, 37],
    },
    {
      week: 3,
      title: 'Round 3',
      a: { id: 'reading',     name: '深読み',   emoji: '📖', desc: '紙の本を30分、スマホなし' },
      b: { id: 'nature-walk', name: '自然散歩', emoji: '🌿', desc: '20分、イヤホンなしで外を歩く' },
      split: [51, 49],
    },
    {
      week: 4,
      title: 'Round 4',
      a: { id: 'cold-shower', name: '冷水シャワー',     emoji: '🚿', desc: '最後の60秒を冷水で締める' },
      b: { id: 'fasting',     name: '間欠的ファスティング', emoji: '⏰', desc: '16:8——食事は12時〜20時のみ' },
      split: [55, 45],
    },
  ];

  var START = new Date('2026-04-28T00:00:00Z');
  var weekIdx = Math.max(0, Math.min(
    Math.floor((Date.now() - START.getTime()) / (7 * 86400000)),
    MATCHUPS.length - 1
  ));
  var M = MATCHUPS[weekIdx];
  var voteKey = 'dopamine-challenge-ja-' + M.week;
  var voted = localStorage.getItem(voteKey);

  document.getElementById('challenge-week-label').textContent =
    'Week ' + M.week + ' / ' + MATCHUPS.length + ' — ' + M.title;

  var archiveEl = document.getElementById('challenge-archive');
  var archiveLinks = MATCHUPS.filter(function(m) { return m.week !== M.week; })
    .map(function(m) {
      var storedChoice = localStorage.getItem('dopamine-challenge-ja-' + m.week);
      var label = m.a.emoji + ' ' + m.a.name + ' vs ' + m.b.emoji + ' ' + m.b.name;
      var badge = storedChoice ? ' <span class="archive-voted">投票済</span>' : '';
      return '<button class="archive-item" data-week="' + m.week + '">' + label + badge + '</button>';
    }).join('');
  if (archiveLinks) {
    archiveEl.innerHTML = '<p class="archive-label">過去のラウンド</p><div class="archive-list">' + archiveLinks + '</div>';
    archiveEl.querySelectorAll('.archive-item').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var w = parseInt(btn.dataset.week);
        var old = MATCHUPS.find(function(m) { return m.week === w; });
        if (!old) return;
        var c = localStorage.getItem('dopamine-challenge-ja-' + w);
        renderMatchup(old, document.getElementById('matchup-view'), document.getElementById('result-view'), 'ja', 'dopamine-challenge-ja-' + w, c);
        document.getElementById('challenge-week-label').textContent =
          'Week ' + old.week + ' / ' + MATCHUPS.length + ' — ' + old.title + '（過去）';
      });
    });
  }

  function ga(event, params) {
    if (typeof window.gtag === 'function') window.gtag('event', event, params || {});
  }

  function renderMatchup(matchup, matchupView, resultView, lang, key, initialVote) {
    if (initialVote) {
      showResult(matchup, resultView, matchupView, lang, key, initialVote);
    } else {
      showMatchup(matchup, matchupView, resultView, lang, key);
    }
  }

  function showMatchup(matchup, matchupView, resultView, lang, key) {
    matchupView.innerHTML =
      '<p class="challenge-prompt" style="font-family:\'Noto Serif JP\',serif">あなたの集中力に効くのはどっち？</p>' +
      '<div class="challenge-vs">' +
        '<button class="habit-btn" data-choice="a">' +
          '<span class="habit-emoji">' + matchup.a.emoji + '</span>' +
          '<strong class="habit-name" style="font-family:\'Noto Serif JP\',serif">' + matchup.a.name + '</strong>' +
          '<span class="habit-desc" style="font-family:\'Noto Serif JP\',serif">' + matchup.a.desc + '</span>' +
        '</button>' +
        '<div class="vs-badge">VS</div>' +
        '<button class="habit-btn" data-choice="b">' +
          '<span class="habit-emoji">' + matchup.b.emoji + '</span>' +
          '<strong class="habit-name" style="font-family:\'Noto Serif JP\',serif">' + matchup.b.name + '</strong>' +
          '<span class="habit-desc" style="font-family:\'Noto Serif JP\',serif">' + matchup.b.desc + '</span>' +
        '</button>' +
      '</div>';
    matchupView.hidden = false;
    resultView.hidden = true;
    matchupView.querySelectorAll('.habit-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var choice = btn.dataset.choice;
        localStorage.setItem(key, choice);
        ga('challenge_vote', { week: matchup.week, choice: choice, lang: lang });
        showResult(matchup, resultView, matchupView, lang, key, choice);
      });
    });
  }

  function showResult(matchup, resultView, matchupView, lang, key, choice) {
    var winner = choice === 'a' ? matchup.a : matchup.b;
    var pctA = matchup.split[0], pctB = matchup.split[1];
    var siteUrl = 'https://dopaminelabtv.com/ja/challenge';
    var shareText =
      'やる気が出ないの、\nサボりじゃないです。脳の問題です。\n\n私は「' + winner.name + '」派 ' + winner.emoji + '\nコミュニティ: ' + matchup.a.name + ' ' + pctA + '% vs ' + matchup.b.name + ' ' + pctB + '%\n\nあなたはどっち？\n' +
      siteUrl + '\n' +
      '#ドーパミン #集中力 #脳科学';
    var xUrl = 'https://twitter.com/intent/tweet?text=' + encodeURIComponent(shareText);

    resultView.innerHTML =
      '<div class="result-header">' +
        '<span class="result-badge">あなたの選択 ' + winner.emoji + '</span>' +
        '<h2 class="result-winner" style="font-family:\'Noto Serif JP\',serif">' + winner.name + '</h2>' +
      '</div>' +
      '<div class="result-bars">' +
        '<div class="result-bar' + (choice === 'a' ? ' result-bar--chosen' : '') + '">' +
          '<div class="result-bar-labels">' +
            '<span>' + matchup.a.emoji + ' ' + matchup.a.name + '</span>' +
            '<strong>' + pctA + '%</strong>' +
          '</div>' +
          '<div class="result-bar-track">' +
            '<div class="result-bar-fill" style="width:' + pctA + '%"></div>' +
          '</div>' +
        '</div>' +
        '<div class="result-bar' + (choice === 'b' ? ' result-bar--chosen' : '') + '">' +
          '<div class="result-bar-labels">' +
            '<span>' + matchup.b.emoji + ' ' + matchup.b.name + '</span>' +
            '<strong>' + pctB + '%</strong>' +
          '</div>' +
          '<div class="result-bar-track">' +
            '<div class="result-bar-fill" style="width:' + pctB + '%"></div>' +
          '</div>' +
        '</div>' +
      '</div>' +
      '<p class="result-note" style="font-family:\'Noto Serif JP\',serif">コミュニティの結果 · Week ' + matchup.week + '</p>' +
      '<div class="result-actions">' +
        '<a class="btn result-share" href="' + xUrl + '" target="_blank" rel="noopener">' +
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0">' +
            '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>' +
          '</svg>' +
          'Xでシェア' +
        '</a>' +
        '<button class="btn-ghost result-retry">← 変更する</button>' +
      '</div>';

    resultView.querySelector('.result-share').addEventListener('click', function() {
      ga('challenge_share', { week: matchup.week, choice: choice, lang: lang });
    });
    resultView.querySelector('.result-retry').addEventListener('click', function() {
      localStorage.removeItem(key);
      showMatchup(matchup, matchupView, resultView, lang, key);
    });

    matchupView.hidden = true;
    resultView.hidden = false;
  }

  renderMatchup(M, document.getElementById('matchup-view'), document.getElementById('result-view'), 'ja', voteKey, voted);
})();
</script>
