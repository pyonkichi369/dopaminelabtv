---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allPosts = await Astro.glob('../../../content/posts/ja/*.md');
const posts = allPosts.sort(
  (a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
const now = Date.now();

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
}
function slug(p: any) { return p.file.split('/').pop().replace('.md', ''); }
function isNew(date: string) { return (new Date(date).getTime() + 14 * 86400000) > now; }
function tagHref(t: string) { return `/ja/tags/${t}`; }
---
<BaseLayout title="全記事" lang="ja" description="Dopamine Lab TVの全記事一覧。">
  <div class="container">
    <section class="posts-section" style="padding-top: 52px;">
      <p class="section-label">全記事 — {posts.length}本</p>
      <div class="search-bar">
        <input
          type="search"
          id="post-search"
          class="search-input"
          placeholder="記事を検索…"
          aria-label="記事を検索"
          autocomplete="off"
        />
      </div>
      <p class="search-empty" id="search-empty" hidden>記事が見つかりませんでした。</p>
      <div class="posts-list">
        {posts.map(post => (
          <article class="post-card">
            <div class="post-card-body">
              <div class="post-tags">
                {isNew(post.frontmatter.date) && <span class="tag-new">NEW</span>}
                {post.frontmatter.tags?.map((t: string) => <a href={tagHref(t)} class="tag">{t}</a>)}
              </div>
              <h2 style="font-family: var(--font-jp)">
                <a href={`/ja/posts/${slug(post)}`}>{post.frontmatter.title}</a>
              </h2>
              <p class="post-excerpt" style="font-family: var(--font-jp)">{post.frontmatter.excerpt}</p>
            </div>
            <div class="post-meta">
              <span class="date">{formatDate(post.frontmatter.date)}</span>
              {post.frontmatter.readTime && <span class="read-time">{post.frontmatter.readTime}分</span>}
            </div>
          </article>
        ))}
      </div>
    </section>
  </div>

<script is:inline>
(function () {
  var input = document.getElementById('post-search');
  var emptyMsg = document.getElementById('search-empty');
  if (!input) return;
  input.addEventListener('input', function () {
    var q = input.value.toLowerCase().trim();
    var cards = document.querySelectorAll('.posts-list .post-card');
    var visible = 0;
    cards.forEach(function (card) {
      var title = (card.querySelector('h2') || {}).textContent || '';
      var excerpt = (card.querySelector('.post-excerpt') || {}).textContent || '';
      var show = !q || title.toLowerCase().includes(q) || excerpt.toLowerCase().includes(q);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyMsg) emptyMsg.hidden = visible > 0;
  });
})();
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: '全記事 — Dopamine Lab TV',
  description: 'Dopamine Lab TVの全記事一覧。神経科学と日本哲学の交差点から。',
  url: 'https://dopaminelabtv.com/ja/posts/',
  inLanguage: 'ja',
  hasPart: posts.map(post => ({
    '@type': 'Article',
    headline: post.frontmatter.title,
    description: post.frontmatter.excerpt,
    url: `https://dopaminelabtv.com/ja/posts/${slug(post)}/`,
    datePublished: post.frontmatter.date,
    inLanguage: 'ja',
    keywords: post.frontmatter.tags?.join(', '),
  })),
})} />
</BaseLayout>
